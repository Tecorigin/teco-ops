op_name: "addTensor"

input {
  id: "x"
  shape: {
    dims: 2
    dims: 3
    dims: 2
    dims: 2
  }
  layout: LAYOUT_NHWC
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data: {
    seed: 15
    upper_bound: 2.0
    lower_bound: 0.0
    distribution: UNIFORM
  }
}

input {
  id: "y"
  shape: {
    dims: 2
    dims: 3
    dims: 2
    dims: 2
  }
  reused : true
  layout: LAYOUT_NHWC
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data: {
    seed: 20
    mu: 1
    sigma: 1
    distribution: GAUSSIAN
  }
}


dnn_param: {
add_tensor_param: {
  alpha: 1.0
  beta: 0.1
}
}