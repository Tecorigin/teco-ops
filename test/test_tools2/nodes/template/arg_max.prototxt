    dims: 1
    dims: 2
    dims: 2
    dims: 2
    dims: 2
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_INT64
  ttype: TENSOR
  }
 

tecoal_param: {
  arg_max_param: {
  axis: 0
  algo: 0
}
}
