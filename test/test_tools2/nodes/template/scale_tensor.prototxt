op_name: "scale_tensor"

input {
  id: "y"
  shape: {
    dims: 3
    dims: 4
    dims: 1
    dims: 3
  }
  layout: LAYOUT_NHWC
  dtype: DTYPE_FLOAT
  ttype: TENSOR
  reused: true
  random_data: {
    seed: 15
    upper_bound: 2.0
    lower_bound: 0.0
    distribution: UNIFORM
  }
}


tecoal_param: {
scale_tensor_param: {
  alpha: 0.5
  algo: ALGO_0
}
}
