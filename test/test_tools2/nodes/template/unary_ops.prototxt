op_name: "unary_ops"

input {
  id: "x"
  shape: {
    dims: 2
    dims: 2
    dims: 2
    dims: 2
  }
  layout: LAYOUT_NHWC
  dtype: DTYPE_FLOAT
  ttype: TENSOR
  random_data: {
    seed: 1024
    upper_bound: 2.0
    lower_bound: 0.0
    distribution: UNIFORM
  }
}

output {
  id: "y"
  shape: {
    dims: 2
    dims: 2
    dims: 2
    dims: 2
  }
  layout: LAYOUT_NHWC
  dtype: DTYPE_FLOAT
  ttype: TENSOR
}


tecoal_param: {
  unary_ops_param: {
    mode: 13
    unary_alpha: 1.0
    algo: 0
  }
}
