op_name: "flash_attention"
input {
  id: "blockTable"
  shape {
    dims: 1
    dims: 16
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_INT32
  ttype: TENSOR
  random_data {
    seed: 100
    lower_bound: 0
    upper_bound: 35844
    distribution: UNIFORM
  }
}
input {
  id: "qData"
  shape {
    dims: 22
    dims: 2
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data {
    seed: 50
    lower_bound: -1.0
    upper_bound: 1.0
    distribution: UNIFORM
  }
}
input {
  id: "kCache"
  shape {
    dims: 35845
    dims: 1
    dims: 32
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data {
    seed: 51
    lower_bound: -1.0
    upper_bound: 1.0
    distribution: UNIFORM
  }
}
input {
  id: "vCache"
  shape {
    dims: 35845
    dims: 1
    dims: 32
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_HALF
  ttype: TENSOR
  random_data {
    seed: 52
    lower_bound: -1.0
    upper_bound: 1.0
    distribution: UNIFORM
  }
}
input {
  id: "q_seq_lens"
  shape {
    dims: 1
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_INT32
  ttype: TENSOR
  prev_value {
    value_i: 22
  }
}
input {
  id: "kv_seq_lens"
  shape {
    dims: 1
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_INT32
  ttype: TENSOR
  prev_value {
    value_i: 22
  }
}
output {
  id: "oData"
  shape {
    dims: 22
    dims: 2
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_HALF
  ttype: TENSOR
  reused: false
}
tecokernel_param {
  flash_attention_param {
    max_seqlen_q: 22
    max_seqlen_k: 22
  }
}
test_param: {
    error_func: DIFF1
    error_threshold: 1e-4
}
